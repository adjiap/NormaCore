# ==============================================================================
# API Service
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ==============================================================================
# Logging
# ==============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/normacore.log

# ==============================================================================
# Vector Store
# ==============================================================================
QDRANT_URL=http://qdrant:6333

# ==============================================================================
# Embedding Service
# ==============================================================================
EMBEDDING_BASE_URL=http://ollama-container:11434
EMBEDDING_MODEL=bge-m3

# ==============================================================================
# Embedding Model Storage
#
# Set to your local embedding models path to use a bind mount instead of a named
# volume. Leave empty to use the managed ollama-data named volume.
# Example: LOCAL_DOWNLOADED_MODELS_MOUNTED=/home/user/.ollama
# ==============================================================================
LOCAL_DOWNLOADED_MODELS_MOUNTED=

# ==============================================================================
# Corpora Storage
#
# Set to your local corpora path to use a custom location.
# Leave empty to use the default ./corpora directory in the repo.
# Example: LOCAL_CORPORA_PATH=/home/user/my-corpora
# ==============================================================================
LOCAL_CORPORA_PATH=
