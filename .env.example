# ==============================================================================
# Vector Store
# ==============================================================================
QDRANT_URL=http://localhost:6333

# ==============================================================================
# Embedding Service (Ollama service)
#
# Internal base URL of the Ollama container — consumed by Ollama itself.
# NormaCore consumes EMBEDDING_BASE_URL instead (see below).
# Override only if running Ollama on a non-standard host or port.
# ==============================================================================
OLLAMA_BASE_URL=http://ollama-container:11434

EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3

# ==============================================================================
# Embedding Model Storage
#
# Set to your local embedding models path to use a bind mount instead of a named
# volume. Leave empty to use the managed ollama-data named volume.
# Example: LOCAL_DOWNLOADED_MODELS_MOUNTED=/home/user/.ollama
# ==============================================================================
LOCAL_DOWNLOADED_MODELS_MOUNTED=
